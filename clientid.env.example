# Twitch Developer Portal credentials for Helix live-status polling.
# Create these at https://dev.twitch.tv/console/apps
clientid=XxX
clientsecret=XxX

# Optional: Twitch browser auth-token cookie for Streamlink playback auth.
# This is not a Twitch Developer Portal OAuth refresh token.
# Treat it like an account secret and do not commit real values.
# oauthtoken=XxX

# Optional Slack webhook path/ID.
# Create a Slack app/webhook at https://api.slack.com/apps
# slackid=XxX

# Optional Telegram notification credentials.
# telegrambottoken=XxX
# telegramchatid=XxX
